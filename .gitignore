# Local-only: Anthropic skill-creator (https://github.com/anthropics/skills/tree/main/skills/skill-creator)
# Intentionally not committed — do not remove this line if you want it to stay off the remote.
.claude/skills/skill-creator/

# Agent working memory — ephemeral, not committed
.agent/

# harness-context request content — local only, not committed to the harness repo
# The empty Outstanding/ and Complete/ dirs are committed (via .gitkeep).
# Request folders inside them are the developer's own work — gitignored here so
# they don't accidentally end up tracked in the overnight-harness remote.
harness-context/Outstanding/*
!harness-context/Outstanding/.gitkeep
harness-context/Complete/*
!harness-context/Complete/.gitkeep
